generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  firstName String?
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
}

model Lead {
  id          String    @id @default(cuid())
  email       String    @unique
  firstName   String?
  consentText String?
  userId      String?
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)
}

model NatalChart {
  id               String    @id @default(cuid())
  userId           String    @unique
  sunSign          String
  moonSign         String
  ascendantSign    String
  chartJson        Json
  technicalSummary String?
  createdAt        DateTime? @default(now()) @db.Timestamptz(6)
}

model GeneratedReport {
  id           String    @id @default(cuid())
  userId       String
  type         String
  title        String
  contentJson  Json
  htmlSnapshot String?
  pdfUrl       String?
  createdAt    DateTime? @default(now()) @db.Timestamptz(6)
}

enum UserRole {
  USER
  ADMIN
}

enum LeadSource {
  LANDING
  QUIZ
  CHECKOUT
  MANUAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum OfferType {
  SUBSCRIPTION
  ONE_SHOT
}

enum ReportType {
  FREE_TEASER
  MONTHLY_PREMIUM
  WEEKLY_UPDATE
  NATAL_ONE_SHOT
}

enum DeliveryChannel {
  EMAIL
  PDF
  DASHBOARD
}
